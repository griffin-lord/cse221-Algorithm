import java.util.Scanner;
public class cse221 {
    public static void main(String[] args) {
        Scanner sc2 = new Scanner(System.in);
        int t=sc2.nextInt();
        long  sum=0;
        for (int i =0; i<t; i++) {
            int n = sc2.nextInt();
            sum = (long) n * (n + 1) / 2;
            System.out.println(sum);
        }
        sc2.close();
    }
}
